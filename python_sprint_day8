# 1 写函数，统计列表中有多少个数同时满足：
# - 是奇数
# - 大于等于 5
def count_odd_ge_5(lst):
    count = 0
    for i in lst:
        if i % 2 != 0 and i >= 5 :
            count += 1
    return count
# 2 写函数，返回字符串中所有不是空格的字符组成的新字符串
def remove_spaces(s):
    new_s = ""
    for i in s :
        if not i == " " :
            new_s += i
    return new_s
# 3 写函数，把列表中每个元素处理后放进新列表返回：
# - 如果这个数大于 10，就减 10
# - 否则保持不变
def minus_10_if_big(lst):
    new_lst = []
    for i in lst :
        if i > 10 :
            new_lst.append(i-10)
        else :
            new_lst.append(i)
    return new_lst
# 4 写函数，判断一个字符串中是否存在字母
# 有的话返回 True，没有返回 False
def has_alpha(s):
    for i in s:
        if i.isalpha():
            return True
    return False
# 5 写函数，统计列表中有多少个字符串同时满足：
# - 长度大于 2
# - 第一个字符是数字
def count_start_digit(lst):
    count = 0
    for i in lst:
        if len(i) > 2 and i[0].isdigit() :
            count += 1
    return count
# 6 写函数，返回字符串中所有不是数字也不是空格的字符组成的新字符串
def remove_digit_and_space(s):
    new_s = ""
    for i in s :
        if not i.isdigit() and not i == " " :
            new_s += i
    return new_s
# 7 写函数，找出列表中的第二小值
# 先默认列表至少有两个元素，且最小值只有一个
def find_second_min(lst):
    min1 = lst[0]
    for i in lst :
        if i < min1 :
            min1 = i
    second = None
    for i in lst :
        if i != min1 :
            second = i
            break
    for i in lst:
        if i != min1 and i < second:
            second = i

    return second
# 8 写函数，统计字符串中有多少个字符同时满足：
# - 是字母
# - 不是大写字母
def count_not_upper_alpha(s):
    count = 0
    for i in s:
        if i.isalpha() and not i.isupper():
            count += 1
    return count
# 9 写函数，把列表中所有奇数变成 0 后放进新列表返回
# 偶数保持不变，也放进新列表
def odd_to_zero(lst):
    new_lst = []
    for i in lst :
        if i % 2 != 0 :
            new_lst.append(0)
        else :
            new_lst.append(i)
    return new_lst
# 10 写函数，判断一个列表中是否所有元素都小于 100
# 全部都小于 100 返回 True，否则返回 False
def all_less_than_100(lst):
    for i in lst:
        if i >= 100:
            return False
    return True
# 11 写函数，统计字符串中不是字母的字符个数
def count_not_alpha(s):
    count = 0
    for i in s:
        if not i.isalpha():
            count += 1
    return count
# 12 写函数，返回一个字符串去掉中间那个字符后的结果
# 先默认字符串长度是奇数，并且至少有 1 个字符
# 先不要用切片

def remove_middle_char(s):
    new_s = ""
    for i in range(len(s)):
        if i != len(s) // 2:
            new_s += s[i]
    return new_s
