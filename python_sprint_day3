# 1 写函数，统计列表里有多少个数同时满足：
# - 是奇数
# - 大于 10
def count_big_odd(lst):
    count = 0
    for i in lst:
        if i % 2 != 0 and i > 10 :
            count += 1
    return count
# 2 写函数，返回字符串中所有数字字符组成的新字符串
def get_digits(s):
    new_s = ""
    for i in s:
        if i.isdigit():
            new_s += i
    return new_s
# 3 写函数，把列表中所有数处理后放进新列表返回：
# - 如果这个数小于 0，就变成它的相反数
# - 如果这个数大于等于 0，就保持不变
def abs_list(lst):
    new_lst = []
    for i in lst:
        if i < 0 :
            new_lst.append(-i)
        else:
            new_lst.append(i)
    return new_lst
# 4 写函数，判断一个字符串中是否有大写字母
# 有的话返回 True，没有返回 False
def has_upper(s):
    for i in s:
        if i.isupper():
            return True
    return False
# 5 写函数，统计列表中有多少个字符串长度等于 3
def count_len3(lst):
    count = 0
    for i in lst:
        if len(i) == 3:
            count += 1
    return count
# 6 写函数，返回字符串中所有不是数字的字符组成的新字符串
def remove_digits(s):
    new_s = ""
    for i in s:
        if not i.isdigit():
            new_s += i
    return new_s
# 7 写函数，找出列表中的最大值
# 先默认列表至少有一个元素
def find_max(lst):
    max1 = lst [0]
    for i in lst :
        if i > max1 :
            max1 = i
    return max1
# 8 写函数，统计字符串里有多少个字符同时满足：
# - 是字母
# - 是小写
def count_lower_alpha(s):
    count = 0
    for i  in s:
        if i.isalpha() and i.islower() :
            count += 1
    return count
# 9 写函数，把列表中所有大于 5 的数平方后放进新列表返回
def square_big_nums(lst):
    new_lst = []
    for i in lst:
        if i > 5 :
            new_lst.append(i**2)
    return new_lst
# 10 写函数，判断一个列表里是否存在负数
# 只要有一个负数，就返回 True，否则返回 False
def has_negative(lst):
    for i in lst:
        if i < 0:
            return True
    return False
# 11 写函数，统计字符串中有多少个元音字母
# 元音字母：aeiouAEIOU
def count_vowels(s):
    count = 0
    for i in s :
        if i in "aeiouAEIOU" :
            count += 1
    return count

# 12 写函数，把一个字符串中的每个字符之间都加上 - 后返回
# 先不要用 join()

def join_with_dash(s):
    new_s = ""
    for i in range(len(s)):
        new_s += s[i]
        if i != len(s) - 1:
            new_s += "-"
    return new_s
