

# 1. 写函数，统计列表里有几个小于 0 的数字
def count_num_low_than10(lst):
    count = 0
    for i in lst:
        if i < 0:
            count += 1
    return count
# 2. 写函数，返回列表里所有大于等于 10 的数字组成的新列表
def find_numbers_ge_10(lst):
    new_lst = []
    for i in lst:
        if i >= 10:
            new_lst.append(i)
    return new_lst

# 3. 写函数，把字符串里所有小写字母变成大写后返回新字符串
def capitalize_all_letters(s):
    new_s = ""
