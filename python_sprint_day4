# 1 写函数，统计列表中有多少个数同时满足：
# - 是偶数
# - 小于 20
def count_small_even(lst):
    count = 0
    for i in lst:
        if i %2 == 0 and i < 20 :
            count += 1
    return count


# 2 写函数，返回字符串中所有大写字母组成的新字符串
def get_upper_letters(s):
    new_s = ""
    for i in s :
        if i.isupper():
            new_s += i
    return new_s
# 3 写函数，把列表中所有小于 10 的数加 1 后放进新列表返回
# 大于等于 10 的数保持不变，也放进新列表
def add_one_if_small(lst):
    new_lst = []
    for i in lst :
        if i < 10 :
            new_lst.append(i+1)
        else:
            new_lst.append(i)
    return new_lst
# 4 写函数，判断一个字符串中是否存在数字字符
# 有的话返回 True，没有返回 False
def has_digit(s):
    for i in s :
        if i.isdigit():
            return True
    return False
# 5 写函数，统计列表中有多少个字符串同时满足：
# - 长度大于 2
# - 最后一个字符是字母
def count_special_strings(lst):
    count = 0
    for i in lst:
        if len(i) > 2 and i[-1].isalpha() :
            count += 1
    return count
# 6 写函数，返回字符串中所有不是大写字母的字符组成的新字符串
def remove_upper(s):
    new_s = ""
    for i in s :
        if not i.isupper():
            new_s += i
    return new_s

# 7 写函数，找出列表中的最小值
# 先默认列表至少有一个元素
def find_min(lst):
    min1 = lst[0]
    for i in lst:
        if i < min1 :
            min1 = i
    return min1
# 8 写函数，统计字符串中有多少个字符同时满足：
# - 是字母
# - 是大写
def count_upper_alpha(s):
    count = 0
    for i in s :
        if i.isalpha() and i.isupper() :
            count += 1
    return count
# 9 写函数，把列表中所有偶数乘 2 后放进新列表返回
# 奇数保持不变，也放进新列表
def double_even(lst):
    new_lst = []
    for i in lst:
        if i %2 == 0 :
            new_lst.append(i*2)
        else:
            new_lst.append(i)
    return new_lst
# 10 写函数，判断一个列表中是否所有元素都是偶数
# 全部是返回 True，否则返回 False
def all_even(lst):
    for i in lst :
        if i % 2 != 0 :
            return False
    return True

# 11 写函数，统计字符串中有多少个字符不是空格
def count_not_space(s):
    count = 0
    for i in s :
        if not i == " " :
            count += 1
    return count
# 12 写函数，把字符串倒序后返回
# 这次仍然先不要用切片
def reverse_string(s):
    new_s = ""
    for i in s :
        new_s = i + new_s
    return new_s
