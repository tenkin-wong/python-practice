# 1 写函数，统计列表中有多少个数同时满足：
# - 是偶数
# - 大于等于 10
def count_even_ge_10(lst):
    count = 0
    for i in lst :
        if i % 2 == 0 and i >= 10 :
            count += 1
    return count
# 2 写函数，返回字符串中所有字母组成的新字符串
def get_alpha(s):
    new_s = ""
    for i in s :
        if i.isalpha():
            new_s += i
    return new_s
# 3 写函数，把列表中每个元素处理后放进新列表返回：
# - 如果这个数小于 0，就加 100
# - 否则保持不变
def add_100_to_negative(lst):
    new_lst = []
    for i in lst :
        if i < 0 :
            new_lst.append(i+100)
        else :
            new_lst.append(i)
    return new_lst
# 4 写函数，判断一个字符串中是否存在空格
# 有的话返回 True，没有返回 False
def has_space(s):
    for i in s :
        if i == " " :
            return True
    return False

# 5 写函数，统计列表中有多少个字符串同时满足：
# - 长度大于 1
# - 最后一个字符是数字
def count_end_digit(lst):
    count = 0
    for i in lst :
        if len(i) > 1 and i[-1].isdigit():
            count += 1
    return count
# 6 写函数，返回字符串中所有不是字母的字符组成的新字符串
def remove_alpha(s):
    new_s = ""
    for i in s :
        if not i.isalpha() :
            new_s += i
    return new_s
# 7 写函数，找出列表中的第二小值
# 先默认列表至少有两个元素，且最小值只有一个
def find_second_min(lst):
    min1 = lst[0]
    for i in lst:
        if i < min1:
            min1 = i
    second = None
    for i in lst:
        if i != min1:
            second = i
            break
    for i in lst:
        if i != min1 and i < second:
            second = i

    return second
# 8 写函数，统计字符串中有多少个字符同时满足：
# - 不是空格
# - 不是字母
def count_not_space_not_alpha(s):
    count = 0
    for i in s :
        if not i.isalpha() and i != " " :
            count += 1
    return count
# 9 写函数，把列表中所有大于 20 的数变成 20 后放进新列表返回
# 其他数保持不变，也放进新列表
def big_to_20(lst):
    new_lst = []
    for i in lst :
        if i > 20 :
            i = 20
            new_lst.append(i)
        else :
            new_lst.append(i)
    return new_lst

# 10 写函数，判断一个列表中是否所有元素都不是负数
# 全部都不是负数返回 True，否则返回 False
def all_not_negative(lst):
    for i in lst :
        if i < 0 :
            return False
    return  True

# 11 写函数，统计字符串中大写字母的个数
def count_upper(s):
    count = 0
    for i in s :
        if i.isupper() :
            count += 1
    return count
# 12 写函数，返回一个字符串去掉最后一个字符后的结果
# 先默认字符串至少有一个字符
# 先不要用切片

def remove_last_char(s):
    new_s = ""
    for i in range(len(s)):
        if i != len(s) - 1:
            new_s += s[i]
    return new_s
