

# 1. 写函数，统计列表里有几个数字同时满足：是偶数 ，小于 20
def count_numbers(lst):
    count = 0
    for i in lst:
        if i%2 == 0 and i <20 :
            count += 1
    return count
# 2. 写函数，返回字符串里所有不是字母的字符组成的新字符串
def backwards_not_letters(s):
    new_s = ""
    for i in s:
        if not i.isalpha():
            new_s += i
    return new_s
# 3. 写函数，返回列表里所有长度小于 5 且全是小写字母的字符串组成的新列表
def backwards_func(lst):
    new_lst = []
    for i in lst:
        if i.islower() and len(i) < 5 :
            new_lst.append(i)
    return new_lst
# 4. 写函数，统计字符串里有几个大写字母是元音字母
def count_capitalized(s):
    count = 0
    for i in s:
        if i.isupper() and i in "AEIOU":
            count += 1
    return count
# 5. 写函数：先找出列表里所有大于 5 的奇数，再把它们乘 2，最后返回新列表
def find_odd_big_than5(lst):
    new_lst = []
    for i in lst:
        if i %2 != 0 and i > 5 :
            new_lst.append(i*2)
    return new_lst
# 6. 写函数：找出字符串里所有数字字符，把它们都加起来，返回总和
def find_numbers(s):
    count = 0
    for i in s:
        if i.isdigit():
            count += int(i)
    return count
# 7. 写函数：统计一个列表里有几个字符串同时满足：是回文字符串 ，长度大于 2
def count_s(lst):
    count = 0
    for i in lst:
        if i == i [::-1] and len(i) > 2 :
            count += 1
    return count
# 8. 写函数：找出列表里所有素数，把这些素数转成字符串后组成一个新列表返回
def is_prime(num):
    if num < 2:
        return False
    for j in range(2, num):
        if num % j == 0:
            return False
    return True

def find_prime_strings(lst):
    new_lst = []
    for i in lst:
        if is_prime(i):
            new_lst.append(str(i))
    return new_lst
