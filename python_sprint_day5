# 1 写函数，统计列表中有多少个数同时满足：
# - 是奇数
# - 小于 30
def count_small_odd(lst):
    count = 0
    for i in lst :
        if i % 2 != 0 and i <30 :
            count += 1
    return count
# 2 写函数，返回字符串中所有小写字母组成的新字符串
def get_lower_letters(s):
    new_s = ""
    for i in s :
        if i.islower() :
            new_s += i
    return new_s
# 3 写函数，把列表中每个元素处理后放进新列表返回：
# - 如果这个数是偶数，就加 10
# - 如果这个数是奇数，就保持不变
def add_ten_to_even(lst):
    new_lst = []
    for i in lst :
        if i % 2 == 0 :
            new_lst.append(i+10)
        else:
            new_lst.append(i)
    return new_lst
# 4 写函数，判断一个字符串中是否存在小写字母
# 有的话返回 True，没有返回 False
def has_lower(s):
    for i in s:
        if i.islower():
            return True
    return False
# 5 写函数，统计列表中有多少个字符串同时满足：
# - 长度大于等于 2
# - 第一个字符是大写字母
def count_head_upper(lst):
    count = 0
    for i in lst:
        if len(i) >= 2 and i[0].isupper():
            count += 1
    return count
# 6 写函数，返回字符串中所有不是小写字母的字符组成的新字符串
def remove_lower(s):
    new_s = ""
    for i in s :
        if not i.islower() :
            new_s  += i
    return new_s
# 7 写函数，找出列表中的第二大值
# 先默认列表至少有两个元素，且最大值只有一个
def find_second_max(lst):
    max1 = lst[0]
    for i in lst:
        if i > max1:
            max1 = i

    second = None
    for i in lst:
        if i != max1:
            second = i
            break

    for i in lst:
        if i != max1 and i > second:
            second = i

    return second
# 8 写函数，统计字符串中有多少个字符同时满足：
# - 不是空格
# - 不是数字
def count_not_space_not_digit(s):
    count = 0
    for i in s :
        if not i.isdigit() and not i == " " :
            count += 1
    return count
# 9 写函数，把列表中所有负数变成 0 后放进新列表返回
# 其他数保持不变，也放进新列表
def negative_to_zero(lst):
    new_lst = []
    for i in lst :
        if i < 0 :
            i = 0
            new_lst.append(i)
        else :
            new_lst.append(i)
    return new_lst
# 10 写函数，判断一个列表中是否所有元素都大于 5
# 全部都大于 5 返回 True，否则返回 False
def all_big_than_5(lst):
    for i in lst:
        if i <= 5:
            return False
    return True
# 11 写函数，统计字符串中数字字符的个数
def count_digits(s):
    count = 0
    for i in s :
        if i.isdigit() :
            count += 1
    return count
# 12 写函数，返回一个字符串去掉第一个字符后的结果
# 先默认字符串至少有一个字符
# 先不要用切片
def remove_first_char(s):
    new_s = ""
    for i in range(len(s)):
        if i != 0:
            new_s += s[i]
    return new_s
