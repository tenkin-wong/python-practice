# 14. 写函数，把列表里所有素数都乘 2 后组成新列表返回
def confirm_prime(num):
    if num < 2:
        return False
    for j in range(2, num):
        if num % j == 0:
            return False
    return True

def prime_number_times2(lst):
    new_lst = []
    for i in lst:
        if confirm_prime(i):
            new_lst.append(i * 2)
    return new_lst
# 15. 写函数，找出字符串里所有大写字母，组成一个新字符串返回
def find_capital_letters(s):
    new_str = ""
    for i in s:
        if i.isupper():
            new_str += i
    return new_str
# 16. 写函数，返回列表里所有长度小于等于 4 的字符串组成的新列表
def create_list_shorter_4(lst):
    new_lst = []
    for i in lst:
        if len(i) <= 4:
            new_lst.append(i)
